{
  "name": "screen-number-scanner",
  "version": "1.0.2",
  "author": "prdxqcy",
  "description": "Electron overlay app with a Python OCR scanner for live number tracking.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "postinstall": "electron-builder install-app-deps",
    "build:runtime": "node scripts/build-python-runtime.js",
    "package": "npm run build:runtime && electron-builder --dir",
    "dist": "npm run build:runtime && electron-builder",
    "release": "npm run build:runtime && electron-builder --publish always"
  },
  "build": {
    "appId": "com.prdxqcy.ocrscanner",
    "productName": "OCR Scanner",
    "icon": "icon.ico",
    "files": [
      "src/**/*",
      "scripts/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python/runtime",
        "to": "python-runtime"
      },
      {
        "from": "python/scanner.py",
        "to": "python-src/scanner.py"
      }
    ],
    "extraFiles": [
      {
        "from": "build/OCR Scanner Launcher.vbs",
        "to": "OCR Scanner Launcher.vbs"
      }
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "prdxqcy",
        "repo": "OCR-Scanner"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "runAfterFinish": false,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
